-- ============================================

local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

if not WindUI then
    game:GetService("StarterGui"):SetCore("SendNotification", {Title = "Error", Text = "WindUI failed to load", Duration = 5})
    return
end

local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- ============ SPEED GLITCH SETTINGS ============
local speedEnabled = false
local speedPower = 3
local macroRotEnabled = false
local macroInterval = 0.01
local lastMacroTick = 0
local wallPush = false
local wallPushPower = 1.2
local forcedDirectionEnabled = false
local forcedDirection = "Forward"
local macroAngleMin = 80
local macroAngleMax = 120

-- ============ HOLD MACRO SPIN SETTINGS ============
local macroSpinActive = false
local spinConnection = nil
local editMode = false
local originalSpeed = 16
local currentBoost = 0
local boostConnection = nil

-- ============ JUMP BOOST SETTINGS ============
local jumpHeight = 50
local jumpCooldown = 1.5
local lastJump = 0

-- ============ CAMERA SPIN (FIXED) ============
local cameraSpinEnabled = false
local cameraSpinConnection = nil
local cameraSpinSpeed = 1.5  -- радиан в секунду

-- ============ GUI ELEMENTS ============
local screenGui = nil
local mcButton = nil
local jbButton = nil
local stopButton = nil

local mcVisible = true
local jbVisible = true
local stopVisible = true

local savedMCPos = UDim2.new(0.85, -65, 0.5, -32)
local savedJBPos = UDim2.new(0.85, -130, 0.5, -32)
local savedStopPos = UDim2.new(0.85, -195, 0.5, -32)

-- ============ DIRECTION LOGIC ============
local function getForcedDirectionVector()
    if not rootPart then return Vector3.zero end
    local look = rootPart.CFrame.LookVector
    local right = rootPart.CFrame.RightVector
    if forcedDirection == "Forward" then return look
    elseif forcedDirection == "Backward" then return -look
    elseif forcedDirection == "Left" then return -right
    elseif forcedDirection == "Right" then return right
    elseif forcedDirection == "Forward Left" then return (look - right).Unit
    elseif forcedDirection == "Forward Right" then return (look + right).Unit
    elseif forcedDirection == "Backward Left" then return (-look - right).Unit
    elseif forcedDirection == "Backward Right" then return (-look + right).Unit
    end
    return look
end

local function getSpeedDirection()
    if not humanoid or not rootPart then return Vector3.zero end
    if forcedDirectionEnabled then
        return getForcedDirectionVector()
    end
    if humanoid.MoveDirection.Magnitude > 0 then
        return humanoid.MoveDirection.Unit
    else
        return Vector3.zero
    end
end

-- ============ SPEED GLITCH ============
RunService.RenderStepped:Connect(function()
    if speedEnabled and humanoid and rootPart and not macroSpinActive then
        local state = humanoid:GetState()
        if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
            local dir = getSpeedDirection()
            if dir.Magnitude > 0 then
                rootPart.AssemblyLinearVelocity += dir * speedPower
            end
        end
    end
end)

-- ============ FAKE MACRO ============
RunService.RenderStepped:Connect(function()
    if macroRotEnabled and humanoid and rootPart and not macroSpinActive then
        if not speedEnabled then
            macroRotEnabled = false
            humanoid.AutoRotate = true
            WindUI:Notify({Title = "Error", Content = "Enable Speed Glitch first", Duration = 2})
            return
        end
        local state = humanoid:GetState()
        if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
            humanoid.AutoRotate = false
            if tick() - lastMacroTick > macroInterval then
                lastMacroTick = tick()
                local dir = (math.random(0,1) == 0) and -1 or 1
                local angle = math.rad(math.random(macroAngleMin, macroAngleMax) * dir)
                rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, angle, 0)
            end
            if wallPush then
                local pushDir = getSpeedDirection()
                if pushDir.Magnitude > 0 then
                    rootPart.AssemblyLinearVelocity += pushDir * wallPushPower
                end
            end
        else
            humanoid.AutoRotate = true
        end
    else
        if humanoid and not macroSpinActive then
            humanoid.AutoRotate = true
        end
    end
end)

-- ============ HOLD MACRO SPIN ============
local function startSpeedRamp()
    if boostConnection then boostConnection:Disconnect() end
    currentBoost = speedPower
    
    boostConnection = RunService.RenderStepped:Connect(function()
        if not macroSpinActive then return end
        if currentBoost < 1000 then
            currentBoost = currentBoost + speedPower * 1.5
        end
        local state = humanoid and humanoid:GetState()
        if state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall then
            local dir = getSpeedDirection()
            if dir.Magnitude > 0 then
                rootPart.AssemblyLinearVelocity = rootPart.AssemblyLinearVelocity + dir * currentBoost
            end
        end
        if humanoid then
            humanoid.WalkSpeed = 16 + currentBoost
        end
    end)
end

local function stopSpeedRamp()
    if boostConnection then
        boostConnection:Disconnect()
        boostConnection = nil
    end
    currentBoost = 0
    if humanoid then
        humanoid.WalkSpeed = originalSpeed
    end
end

local function startSpin()
    if macroSpinActive then return end
    macroSpinActive = true
    if humanoid then
        originalSpeed = humanoid.WalkSpeed
    end
    startSpeedRamp()
    
    spinConnection = RunService.RenderStepped:Connect(function()
        if not macroSpinActive then return end
        if tick() - lastMacroTick > macroInterval then
            lastMacroTick = tick()
            local dir = (math.random(0,1) == 0) and -1 or 1
            local angle = math.rad(math.random(macroAngleMin, macroAngleMax) * dir)
            if rootPart then
                rootPart.CFrame = rootPart.CFrame * CFrame.Angles(0, angle, 0)
            end
        end
    end)
    
    WindUI:Notify({Title = "Macro Spin", Content = "ON", Duration = 1})
end

local function stopSpin()
    if not macroSpinActive then return end
    macroSpinActive = false
    if spinConnection then spinConnection:Disconnect() spinConnection = nil end
    stopSpeedRamp()
    lastMacroTick = 0
end

-- ============ JUMP BOOST ============
local function doJumpBoost()
    if not rootPart or not humanoid or humanoid.Health <= 0 then
        WindUI:Notify({Title = "Error", Content = "Character not ready", Duration = 1})
        return
    end
    
    local now = tick()
    if now - lastJump < jumpCooldown then
        WindUI:Notify({Title = "Cooldown", Content = string.format("%.1f sec left", jumpCooldown - (now - lastJump)), Duration = 1})
        return
    end
    
    local g = 196.2
    local velocity = math.sqrt(2 * g * jumpHeight)
    rootPart.AssemblyLinearVelocity = Vector3.new(rootPart.AssemblyLinearVelocity.X, velocity, rootPart.AssemblyLinearVelocity.Z)
    lastJump = now
    
    WindUI:Notify({Title = "Jump Boost", Content = "Height: " .. jumpHeight .. " blocks", Duration = 1})
end

-- ============ STOP CHARACTER ============
local function stopCharacter()
    if not rootPart or not humanoid then
        WindUI:Notify({Title = "Error", Content = "Character not ready", Duration = 1})
        return
    end
    
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero
    rootPart.Velocity = Vector3.zero
    humanoid.WalkSpeed = 0
    humanoid.JumpPower = 0
    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
    
    if macroSpinActive then
        stopSpin()
        if mcButton then mcButton.BackgroundColor3 = Color3.fromRGB(100, 100, 255) end
    end
    
    WindUI:Notify({Title = "STOP", Content = "Character frozen", Duration = 1})
    
    task.wait(0.5)
    if humanoid and not macroSpinActive then
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
    end
end

-- ============ CAMERA SPIN (РАБОЧАЯ ВЕРСИЯ) ============
local angle = 0

local function updateCameraSpin()
    if not cameraSpinEnabled then return end
    if not rootPart then return end
    
    angle = angle + cameraSpinSpeed * RunService.RenderStepped:Wait()
    
    local characterPos = rootPart.Position
    local distance = (Camera.CFrame.Position - characterPos).Magnitude
    
    local newX = characterPos.X + math.cos(angle) * distance
    local newZ = characterPos.Z + math.sin(angle) * distance
    
    local newPos = Vector3.new(newX, characterPos.Y + 2, newZ)
    Camera.CFrame = CFrame.new(newPos, characterPos)
end

local function startCameraSpin()
    if cameraSpinConnection then cameraSpinConnection:Disconnect() end
    angle = 0
    cameraSpinConnection = RunService.RenderStepped:Connect(updateCameraSpin)
end

local function stopCameraSpin()
    if cameraSpinConnection then
        cameraSpinConnection:Disconnect()
        cameraSpinConnection = nil
    end
end

local function setCameraSpinEnabled(enabled)
    cameraSpinEnabled = enabled
    if enabled then
        startCameraSpin()
        WindUI:Notify({Title = "Camera Spin", Content = "ON", Duration = 2})
    else
        stopCameraSpin()
        WindUI:Notify({Title = "Camera Spin", Content = "OFF", Duration = 1})
    end
end

-- ============ GUI КНОПКИ ============
local function createButtons()
    if screenGui then screenGui:Destroy() end
    
    screenGui = Instance.new("ScreenGui")
    screenGui.Name = "MacroButton"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = player:WaitForChild("PlayerGui")
    
    -- MC Button
    mcButton = Instance.new("TextButton")
    mcButton.Name = "MCButton"
    mcButton.Size = UDim2.new(0, 65, 0, 65)
    mcButton.Position = savedMCPos
    mcButton.BackgroundColor3 = Color3.fromRGB(100, 100, 255)
    mcButton.BackgroundTransparency = 0
    mcButton.BorderSizePixel = 2
    mcButton.BorderColor3 = Color3.fromRGB(255, 255, 255)
    mcButton.Text = "MC"
    mcButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    mcButton.TextScaled = true
    mcButton.Font = Enum.Font.GothamBold
    mcButton.Visible = mcVisible
    mcButton.Parent = screenGui
    Instance.new("UICorner", mcButton).CornerRadius = UDim.new(1, 0)
    
    -- JB Button
    jbButton = Instance.new("TextButton")
    jbButton.Name = "JBButton"
    jbButton.Size = UDim2.new(0, 65, 0, 65)
    jbButton.Position = savedJBPos
    jbButton.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
    jbButton.BackgroundTransparency = 0
    jbButton.BorderSizePixel = 2
    jbButton.BorderColor3 = Color3.fromRGB(255, 255, 255)
    jbButton.Text = "JB"
    jbButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    jbButton.TextScaled = true
    jbButton.Font = Enum.Font.GothamBold
    jbButton.Visible = jbVisible
    jbButton.Parent = screenGui
    Instance.new("UICorner", jbButton).CornerRadius = UDim.new(1, 0)
    
    -- STOP Button
    stopButton = Instance.new("TextButton")
    stopButton.Name = "STOPButton"
    stopButton.Size = UDim2.new(0, 65, 0, 65)
    stopButton.Position = savedStopPos
    stopButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
    stopButton.BackgroundTransparency = 0
    stopButton.BorderSizePixel = 2
    stopButton.BorderColor3 = Color3.fromRGB(255, 255, 255)
    stopButton.Text = "STOP"
    stopButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    stopButton.TextScaled = true
    stopButton.Font = Enum.Font.GothamBold
    stopButton.Visible = stopVisible
    stopButton.Parent = screenGui
    Instance.new("UICorner", stopButton).CornerRadius = UDim.new(1, 0)
    
    -- Сохраняем позиции
    task.spawn(function()
        while mcButton and jbButton and stopButton do
            task.wait(0.5)
            if mcButton then savedMCPos = mcButton.Position end
            if jbButton then savedJBPos = jbButton.Position end
            if stopButton then savedStopPos = stopButton.Position end
        end
    end)
    
    -- MC HOLD
    mcButton.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not editMode then
            startSpin()
            mcButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        end
    end)
    mcButton.InputEnded:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not editMode then
            stopSpin()
            mcButton.BackgroundColor3 = Color3.fromRGB(100, 100, 255)
        end
    end)
    
    -- JB CLICK
    jbButton.MouseButton1Click:Connect(function()
        if not editMode then
            doJumpBoost()
            local originalColor = jbButton.BackgroundColor3
            jbButton.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
            task.wait(0.1)
            jbButton.BackgroundColor3 = originalColor
        end
    end)
    
    -- STOP CLICK
    stopButton.MouseButton1Click:Connect(function()
        if not editMode then
            stopCharacter()
            local originalColor = stopButton.BackgroundColor3
            stopButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
            task.wait(0.2)
            stopButton.BackgroundColor3 = originalColor
        end
    end)
    
    -- DRAG
    local dragging = false
    local dragStart = nil
    local startPos = nil
    local activeButton = nil
    
    local function beginDrag(btn, input)
        if editMode then
            dragging = true
            activeButton = btn
            dragStart = input.Position
            startPos = btn.Position
            btn.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
        end
    end
    
    local function updateDrag(input)
        if dragging and editMode and activeButton then
            local delta = input.Position - dragStart
            local newX = startPos.X.Offset + delta.X
            local newY = startPos.Y.Offset + delta.Y
            activeButton.Position = UDim2.new(0, newX, 0, newY)
        end
    end
    
    local function endDrag()
        if dragging and editMode and activeButton then
            dragging = false
            if activeButton == mcButton then
                mcButton.BackgroundColor3 = macroSpinActive and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(100, 100, 255)
                savedMCPos = mcButton.Position
            elseif activeButton == jbButton then
                jbButton.BackgroundColor3 = Color3.fromRGB(255, 100, 0)
                savedJBPos = jbButton.Position
            elseif activeButton == stopButton then
                stopButton.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                savedStopPos = stopButton.Position
            end
            activeButton = nil
        end
    end
    
    mcButton.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then beginDrag(mcButton, input) end end)
    jbButton.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then beginDrag(jbButton, input) end end)
    stopButton.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then beginDrag(stopButton, input) end end)
    
    UserInputService.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then updateDrag(input) end end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then endDrag() end end)
end

-- ============ РЕСПАВН ============
local function onCharacterAdded(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    rootPart = newChar:WaitForChild("HumanoidRootPart")
    
    if macroSpinActive then
        stopSpin()
        if mcButton then mcButton.BackgroundColor3 = Color3.fromRGB(100, 100, 255) end
    end
    
    createButtons()
end

player.CharacterAdded:Connect(onCharacterAdded)

